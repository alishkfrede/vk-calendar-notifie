# Google OAuth (получить в Google Cloud Console)
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# VK API (получить в настройках сообщества)
VK_SERVICE_TOKEN=vk1.a.your_service_token_here
VK_GROUP_ID=123456789

# Database
DATABASE_URL=sqlite:///./notifications.db
# Для PostgreSQL: postgresql://user:password@localhost/dbname

# Security (минимум 32 случайных символа)
ENCRYPTION_KEY=change-me-to-random-32-chars-string

# App
DEBUG=True